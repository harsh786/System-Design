  {
    "id": "multi_step_booking",
    "description": "Search for flights and book the cheapest one",
    "input": "Find the cheapest flight from NYC to London next Friday and book it",
    "expected_outcome": "Searches flights, identifies cheapest, books it",
    "golden_trajectory": [
      {"tool": "search_flights", "args": {"from": "NYC", "to": "London", "date": "next_friday"}},
      {"tool": "sort_results", "args": {"by": "price", "order": "asc"}},
      {"tool": "book_flight", "args": {"flight_id": "cheapest"}}
    ],
    "max_steps": 5,
    "required_tools": ["search_flights", "book_flight"],
    "forbidden_tools": ["cancel_flight", "delete_account"],
    "expected_result_contains": ["booked", "confirmation"]
  },
