    "input": "What's the weather like in Tokyo right now?",
    "expected_outcome": "Returns current weather conditions for Tokyo",
    "golden_trajectory": [
      {"tool": "get_weather", "args": {"city": "Tokyo"}}
    ],
    "max_steps": 2,
    "required_tools": ["get_weather"],
    "forbidden_tools": ["send_email", "delete_data"],
    "expected_result_contains": ["Tokyo", "temperature"]
