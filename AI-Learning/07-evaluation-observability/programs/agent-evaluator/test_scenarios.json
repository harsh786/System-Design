    "golden_trajectory": [
      {"tool": "lookup_order", "args": {"email": "user@example.com"}},
      {"tool": "send_notification", "args": {"to": "user@example.com", "type": "order_update"}}
    ],
    "max_steps": 4,
    "required_tools": ["lookup_order", "send_notification"],
    "forbidden_tools": ["delete_user", "modify_order"],
