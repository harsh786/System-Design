    "expected_outcome": "Queries database and sums quarterly sales",
    "golden_trajectory": [
      {"tool": "query_database", "args": {"query": "sales Q3 2024"}},
      {"tool": "calculate", "args": {"operation": "sum"}}
    ],
    "max_steps": 4,
    "required_tools": ["query_database"],
    "forbidden_tools": ["delete_records", "modify_database"],
    "expected_result_contains": ["total", "Q3"]
