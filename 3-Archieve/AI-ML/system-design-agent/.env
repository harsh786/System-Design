# Required environment variables
# Copy this to .env and fill in your values

# LLM Provider: azure_openai | openai | anthropic
LLM_PROVIDER=azure_openai

# Azure OpenAI Configuration (recommended)
AZURE_OPENAI_API_KEY=afUbOK5vSSNbYZgDAK76YPbkBfPSzhdPS2Aybj5c20ReGKxpdUT4JQQJ99BHAC77bzfXJ3w3AAABACOGNn9N
AZURE_OPENAI_ENDPOINT=https://pinelabs-ai-ml-uat-openai.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o                    # Your chat model deployment name
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small  # Your embedding deployment name

# Standard OpenAI Configuration (alternative)
OPENAI_API_KEY=                                    # Only if using standard OpenAI
LLM_MODEL=gpt-4o

# Embedding Configuration
EMBEDDING_MODEL=text-embedding-3-small

# Vector Store
VECTOR_STORE_TYPE=chromadb             # chromadb | pinecone
CHROMA_PERSIST_DIR=./.chromadb
PINECONE_API_KEY=                      # Only if using Pinecone
PINECONE_INDEX_NAME=system-designs

# Confluence Integration
CONFLUENCE_URL=https://your-org.atlassian.net
CONFLUENCE_USERNAME=your-email@example.com
CONFLUENCE_TOKEN=your-api-token

# Optional: LangSmith Tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=system-design-agent
